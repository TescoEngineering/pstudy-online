# Copy this file to .env.local and fill in your values
# See SUPABASE-SETUP-GUIDE.md for Supabase setup
# See GOOGLE-CLOUD-SETUP.md for optional Speech-to-Text (better recognition with "Consider only deck answers")

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Canonical public URL (no trailing slash). Production: https://pstudy.be
# Used for beta invite redirectTo, deck review links, etc. Falls back to request Host when unset.
NEXT_PUBLIC_APP_URL=https://pstudy.be

# Marketing CTAs routing:
# - false/unset: "Join the private beta" routes to /signup
# - true: routes to Paddle Checkout (see src/lib/cta-routing.ts)
NEXT_PUBLIC_PAYMENTS_LIVE=false

# Private beta cap (used by /api/beta-signup). Defaults to 50 if unset/invalid.
BETA_SIGNUP_CAP=50

# Optional: Google Cloud Speech-to-Text (for better recognition when "Consider only deck answers" is on)
# Option A (local): Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# Option B (Vercel/production): Full JSON content as a string
# GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account",...}
